generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QuestionnaireSubmission {
  id                String   @id @default(cuid())
  questionnaireSlug String
  fullName          String?
  email             String?
  phone             String?
  whatsappOptIn     Boolean  @default(false)
  answers           Json
  createdAt         DateTime @default(now())

  @@index([questionnaireSlug])
  @@index([email])
  @@index([createdAt])
}