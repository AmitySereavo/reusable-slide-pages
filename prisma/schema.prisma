generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model QuestionnaireSubmission {
  id                String   @id @default(cuid())
  questionnaireSlug String
  fullName          String?
  email             String?
  phone             String?
  whatsappOptIn     Boolean  @default(false)
  answers           Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @default(now()) @updatedAt
}

model Plant {
  id             String  @id @default(cuid())
  slug           String  @unique
  name           String
  displayName    String?
  scientificName String?
  description    String?
  active         Boolean @default(true)

  // plant identity
  plantKind      PlantKind
  plantCategory  PlantCategory?
  lifecycleStage PlantLifecycleStage?

  // media
  imageUrl     String?
  thumbnailUrl String?

  // basic commercial status
  quantityAvailable Int @default(0)
  quantityReserved  Int @default(0)

  basePriceJmd      Decimal? @db.Decimal(10, 2)
  compareAtPriceJmd Decimal? @db.Decimal(10, 2)

  // storefront visibility
  visibleInPlantShop Boolean @default(false)
  purchasable        Boolean @default(false)

  // claim-flow visibility
  claimEligible       Boolean @default(false)
  claimSwitchEligible Boolean @default(false)
  claimFeatured       Boolean @default(false)

  // delivery / pickup
  supportsPickup   Boolean @default(true)
  supportsDelivery Boolean @default(false)

  // customer experience modes
  supportsSeedJourney         Boolean @default(false)
  supportsMatureNow           Boolean @default(false)
  supportsCircumposingJourney Boolean @default(false)
  supportsReservation         Boolean @default(false)
  supportsGrowthUpdates       Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  inventory       PlantInventory?
  marketing       PlantMarketingContent?
  questionnaire   PlantQuestionnaireContent?
  offerModes      PlantOfferMode[]
  channelSettings PlantChannelSetting[]
  shopSizeOptions PlantShopSizeOption[]
}

model PlantInventory {
  id      String @id @default(cuid())
  plantId String @unique
  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)

  stockOnHand    Int @default(0)
  stockCommitted Int @default(0)
  stockAvailable Int @default(0)

  propagationMethod PlantPropagationMethod?
  propagationStatus PlantPropagationStatus?

  batchCode          String?
  readyNow           Boolean   @default(false)
  estimatedReadyDate DateTime?
  readinessNote      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlantMarketingContent {
  id      String @id @default(cuid())
  plantId String @unique
  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)

  // structured benefit fields
  primaryBenefit     String?
  healthBenefit      String?
  nutritionBenefit   String?
  healingBenefit     String?
  environmentBenefit String?
  incomeBenefit      String?
  savingsBenefit     String?

  // yield / financial angle
  yieldType               PlantYieldType?
  yieldFrequency          String?
  yieldQuantityEstimate   String?
  monetaryValueNote       String?
  savingsAmountJmdMonthly Decimal?        @db.Decimal(10, 2)

  // reusable marketing copy
  adHook            String?
  adCopyShort       String?
  adCopyMedium      String?
  plantShopSummary  String?
  whatsappPromoCopy String?
  claimPageSnippet  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlantQuestionnaireContent {
  id      String @id @default(cuid())
  plantId String @unique
  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)

  // questionnaire-specific styled content / blocks
  seedRevealBlock   String?
  plantInfoBlock    String?
  updatesIntroBlock String?
  careTipsBlock     String?
  confirmationBlock String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlantOfferMode {
  id      String @id @default(cuid())
  plantId String
  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)

  offerMode PlantOfferModeType
  enabled   Boolean            @default(true)

  label       String?
  description String?

  priceJmd          Decimal? @db.Decimal(10, 2)
  compareAtPriceJmd Decimal? @db.Decimal(10, 2)

  leadTimeDays        Int?
  requiresUpdates     Boolean @default(false)
  requiresReservation Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plantId, offerMode])
}

model PlantChannelSetting {
  id      String @id @default(cuid())
  plantId String
  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)

  channel  PlantSalesChannel
  visible  Boolean           @default(false)
  featured Boolean           @default(false)
  priority Int               @default(0)

  // claim specific overrides
  claimEligible       Boolean?
  claimSwitchEligible Boolean?
  claimFeatured       Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([plantId, channel])
}

model PlantShopSizeOption {
  id      String @id @default(cuid())
  plantId String
  plant   Plant  @relation(fields: [plantId], references: [id], onDelete: Cascade)

  slug        String?
  label       String
  description String?

  active    Boolean @default(true)
  featured  Boolean @default(false)
  sortOrder Int     @default(0)

  priceJmd          Decimal  @db.Decimal(10, 2)
  compareAtPriceJmd Decimal? @db.Decimal(10, 2)

  weight     Decimal?    @db.Decimal(10, 3)
  weightUnit WeightUnit?

  stockOnHand    Int @default(0)
  stockReserved  Int @default(0)
  stockAvailable Int @default(0)

  supportsPickup   Boolean?
  supportsDelivery Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseModes PlantShopSizeOptionPurchaseMode[]

  @@unique([plantId, label])
  @@index([plantId, active, sortOrder])
}

model PlantShopSizeOptionPurchaseMode {
  id           String              @id @default(cuid())
  sizeOptionId String
  sizeOption   PlantShopSizeOption @relation(fields: [sizeOptionId], references: [id], onDelete: Cascade)

  modeType    PlantShopPurchaseModeType
  label       String
  description String?

  active    Boolean @default(true)
  featured  Boolean @default(false)
  sortOrder Int     @default(0)

  priceAdjustmentJmd Decimal @db.Decimal(10, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sizeOptionId, modeType])
  @@index([sizeOptionId, active, sortOrder])
}

enum PlantKind {
  SEED
  SEEDLING
  MATURE_PLANT
  CIRCUMPOSED_PLANT
  CUTTING
  TREE
  HERB
  VEGETABLE
  FRUIT_PLANT
  ORNAMENTAL
  AIR_PURIFIER
  OTHER
}

enum PlantCategory {
  HERB
  VEGETABLE
  FRUIT
  ORNAMENTAL
  SHADE
  AIR_PURIFYING
  MEDICINAL
  FLOWERING
  OTHER
}

enum PlantLifecycleStage {
  SEED
  GERMINATING
  SEEDLING
  YOUNG_PLANT
  MATURE
  PROPAGATING
  READY_FOR_PICKUP
  READY_FOR_DELIVERY
}

enum PlantPropagationMethod {
  SEED
  CUTTING
  CIRCUMPOSING
  SUCKER
  GRAFT
  DIVISION
  OTHER
}

enum PlantPropagationStatus {
  PLANNED
  IN_PROGRESS
  ROOTING
  GROWING
  HARDENING
  READY
  DELIVERED
}

enum PlantSalesChannel {
  CLAIM_FLOW
  PLANT_SHOP
  POPUP_SHOP
  WHOLESALE
  PARTNER_PORTAL
  ADMIN_ONLY
}

enum PlantOfferModeType {
  CLAIM_FREE
  SWITCH_FREE
  WATCH_FROM_SEED
  GROWTH_UPDATES
  BUY_MATURE_NOW
  RESERVE_MATURE
  WATCH_CIRCUMPOSING
  PREORDER
}

enum PlantYieldType {
  FRUIT
  LEAVES
  FLOWERS
  SEEDS
  SUCKERS
  CUTTINGS
  AIR_QUALITY
  SHADE
  OTHER
}

enum WeightUnit {
  OZ
  LB
  G
  KG
}

enum PlantShopPurchaseModeType {
  WATCH_FROM_START
  BUY_MATURE_NOW
  RESERVE_FOR_LATER
  SUBSCRIBE_TO_UPDATES
  STANDARD
  OTHER
}

model PlantType {
  id             String  @id @default(cuid())
  slug           String  @unique
  name           String
  displayName    String?
  scientificName String?

  category      NurseryPlantCategory?
  form          NurseryPlantForm?
  lifecycleType NurseryLifecycleType?

  description String?

  prefersShade      Boolean?
  prefersPartialSun Boolean?
  prefersFullSun    Boolean?

  preferredTemperatureMinC Decimal? @db.Decimal(5, 2)
  preferredTemperatureMaxC Decimal? @db.Decimal(5, 2)

  preferredHumidityNotes String?
  preferredMediumNotes   String?
  preferredSoilNotes     String?
  preferredWateringNotes String?

  averageHeightCmMin Decimal? @db.Decimal(8, 2)
  averageHeightCmMax Decimal? @db.Decimal(8, 2)

  blooms     Boolean?
  bloomNotes String?
  fruits     Boolean?
  fruitNotes String?

  indoorSuitable    Boolean?
  citySuitable      Boolean?
  coolAreaSuitable  Boolean?
  hotAreaSuitable   Boolean?
  windyAreaSuitable Boolean?

  diseaseProne   Boolean?
  diseaseNotes   String?
  treatmentNotes String?

  ornamental    Boolean  @default(false)
  edible        Boolean  @default(false)
  medicinal     Boolean  @default(false)
  shadeTree     Boolean  @default(false)
  fruitProducer Boolean  @default(false)
  sellable      Boolean  @default(true)
  profitable    Boolean?

  healthBenefits        String?
  environmentalBenefits String?
  commercialBenefits    String?
  economicBenefits      String?

  maintenanceDifficulty NurseryMaintenanceDifficulty?
  usageNotes            String?
  companionPlantNotes   String?

  attractsBirds             Boolean?
  attractsBeneficialInsects Boolean?
  attractsPollinators       Boolean?
  attractsPests             Boolean?
  invasiveRiskNotes         String?

  adCopyShort           String?
  adCopyBasicNeeds      String?
  adCopyHealthBenefit   String?
  adCopyEconomicBenefit String?
  adCopyEnvironmental   String?
  adCopyEasyGrow        String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches PlantBatch[]
  media   PlantMedia[]
}

model PlantBatch {
  id   String @id @default(cuid())
  code String @unique

  plantTypeId String
  plantType   PlantType @relation(fields: [plantTypeId], references: [id], onDelete: Cascade)

  startMethod    PlantStartMethod
  startDate      DateTime
  transplantDate DateTime?

  quantityStarted      Int @default(0)
  quantityTransplanted Int @default(0)
  quantityAlive        Int @default(0)
  quantityLost         Int @default(0)
  quantitySold         Int @default(0)
  quantityGifted       Int @default(0)

  intendedUse     BatchIntendedUse
  targetBuyerType BatchBuyerType?
  targetBuyerName String?

  sourceType  PlantSourceType?
  sourceName  String?
  sourceNotes String?

  containerId String?
  container   Container? @relation(fields: [containerId], references: [id], onDelete: SetNull)

  mediumId String?
  medium   GrowingMedium? @relation(fields: [mediumId], references: [id], onDelete: SetNull)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  labeledForSale Boolean   @default(false)
  labelPrintedAt DateTime?

  startMediumSnapshot String?
  containerSnapshot   String?
  locationSnapshot    String?
  startNotes          String?
  commercialNotes     String?

  active   Boolean @default(true)
  archived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  units      PlantUnit[]
  activities PlantActivity[]
  reminders  Reminder[]
  media      PlantMedia[]

  @@index([plantTypeId, startDate])
  @@index([intendedUse, targetBuyerType])
}

model PlantUnit {
  id   String @id @default(cuid())
  code String @unique

  batchId String
  batch   PlantBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  sequenceNumber Int
  unitKind       PlantUnitKind @default(BATCH_INDIVIDUAL)

  parentUnitId String?
  parentUnit   PlantUnit?  @relation("PlantUnitChildren", fields: [parentUnitId], references: [id], onDelete: SetNull)
  children     PlantUnit[] @relation("PlantUnitChildren")

  batchContainerSequence      Int?
  transplantContainerSequence Int?

  status          PlantUnitStatus       @default(ACTIVE)
  conditionStatus PlantConditionStatus?

  containerId String?
  container   Container? @relation(fields: [containerId], references: [id], onDelete: SetNull)

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  labeledForSale Boolean   @default(false)
  labelPrintedAt DateTime?

  transplantDate DateTime?
  soldAt         DateTime?
  giftedAt       DateTime?
  lostAt         DateTime?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities PlantActivity[]
  reminders  Reminder[]
  media      PlantMedia[]

  @@unique([batchId, sequenceNumber])
  @@index([batchId, status])
  @@index([batchId, unitKind])
  @@index([parentUnitId])
}

model Container {
  id   String @id @default(cuid())
  code String @unique

  type        ContainerType
  description String?

  lengthCm     Decimal? @db.Decimal(8, 2)
  widthCm      Decimal? @db.Decimal(8, 2)
  depthCm      Decimal? @db.Decimal(8, 2)
  diameterCm   Decimal? @db.Decimal(8, 2)
  volumeLiters Decimal? @db.Decimal(8, 2)

  condition ContainerCondition?
  reusable  Boolean             @default(true)
  active    Boolean             @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches PlantBatch[]
  units   PlantUnit[]
}

model GrowingMedium {
  id   String @id @default(cuid())
  code String @unique

  name        String
  type        GrowingMediumType
  quality     MediumQuality?
  description String?

  compositionNotes String?
  drainageNotes    String?
  moistureNotes    String?
  fertilityNotes   String?
  sourceNotes      String?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches PlantBatch[]
}

model Location {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  description String?

  exposure        SunExposure?
  temperatureMinC Decimal?     @db.Decimal(5, 2)
  temperatureMaxC Decimal?     @db.Decimal(5, 2)

  humidityNotes String?
  indoor        Boolean?
  outdoor       Boolean?

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batches PlantBatch[]
  units   PlantUnit[]
}

model PlantActivity {
  id String @id @default(cuid())

  batchId String
  batch   PlantBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  unitId String?
  unit   PlantUnit? @relation(fields: [unitId], references: [id], onDelete: Cascade)

  activityType PlantActivityType
  activityAt   DateTime

  quantityAffected Int?
  performedBy      String?

  waterType      WaterType?
  wateringMethod WateringMethod?
  amountValue    Decimal?        @db.Decimal(10, 2)
  amountUnit     String?
  skipReason     String?

  feedType     FeedType?
  feedStrength String?
  feedNotes    String?

  pestTreatmentType PestTreatmentType?
  pestProductName   String?
  pestStrength      String?
  targetPest        String?
  pestResultNotes   String?

  oldLocationId    String?
  newLocationId    String?
  locationReason   String?
  locationSnapshot String?

  conditionStatus PlantConditionStatus?
  vigorRating     Int?
  moistureStatus  MoistureStatus?
  pestObserved    Boolean?
  diseaseObserved Boolean?
  symptomNotes    String?

  transplantQuantity Int?
  labeledSetTo       Boolean?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId, activityAt])
  @@index([unitId, activityAt])
  @@index([activityType, activityAt])
}

model PlantMedia {
  id String @id @default(cuid())

  plantTypeId String?
  plantType   PlantType? @relation(fields: [plantTypeId], references: [id], onDelete: SetNull)

  batchId String?
  batch   PlantBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)

  unitId String?
  unit   PlantUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)

  mediaType PlantMediaType
  usageType MediaUsageType

  filePath   String
  caption    String?
  altText    String?
  capturedAt DateTime?
  isPrimary  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([plantTypeId, mediaType])
  @@index([batchId, mediaType])
  @@index([unitId, mediaType])
}

model Reminder {
  id String @id @default(cuid())

  batchId String?
  batch   PlantBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)

  unitId String?
  unit   PlantUnit? @relation(fields: [unitId], references: [id], onDelete: Cascade)

  type        ReminderType
  title       String
  description String?

  dueAt          DateTime
  recurrenceRule String?
  status         ReminderStatus @default(PENDING)

  completedAt DateTime?
  skippedAt   DateTime?
  skipReason  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dueAt, status])
  @@index([batchId, status])
  @@index([unitId, status])
}

